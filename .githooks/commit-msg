#!/usr/bin/env bash
# commit-msg: block commits whose message contains forbidden bot signatures.
#
# Catches anything that reaches the local repo — including commits made
# outside Claude Code (manual `git commit`, IDE integrations, scripted
# commits, other AI agents). Pairs with the Claude Code PreToolUse hook
# and the Commit Guard GitHub Action.

set -u

msg_file="$1"

patterns='Claude|Anthropic|Co-Authored-By:[[:space:]]*Claude|🤖 Generated with \[Claude Code\]'

if grep -qiE "$patterns" "$msg_file"; then
  match="$(grep -iEn "$patterns" "$msg_file" | head -3)"
  cat >&2 <<EOF

✖ commit-msg hook blocked this commit.

Forbidden pattern matched in commit message:
$match

Policy: no Claude / Anthropic / AI attribution in commits.
Forbidden: Claude, Anthropic, Co-Authored-By: Claude, 🤖 Generated with [Claude Code]

Edit the message (\`git commit --edit\` or amend) and retry.

EOF
  exit 1
fi

exit 0
