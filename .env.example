# ============================================================================
# PDW (Personal Data Wallet) Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains sensitive keys!

# ============================================================================
# Sui Network Configuration
# ============================================================================
SUI_NETWORK=testnet                    # testnet | mainnet

# ============================================================================
# PDW Smart Contract Configuration
# Deploy smart contract and get these IDs from deployment output
# Run: cd packages/smart-contract && sui client publish --gas-budget 100000000
# ============================================================================
PACKAGE_ID=0x_your_package_id_here
ACCESS_REGISTRY_ID=0x_your_access_registry_id_here
WALLET_REGISTRY_ID=0x_your_wallet_registry_id_here

# ============================================================================
# Sui Wallet (IMPORTANT - never commit to git!)
# Get from: sui keytool export --key-identity <alias>
# ============================================================================
WALLET_ADDRESS=0x_your_wallet_address_here
SUI_PRIVATE_KEY=suiprivkey1q_your_private_key_here

# ============================================================================
# Walrus Configuration (Decentralized Storage)
# https://docs.walrus.site/
# ============================================================================
WALRUS_NETWORK=testnet                 # testnet | mainnet
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# ============================================================================
# Embedding Configuration (AI Vector Embeddings)
# Choose one provider - OpenRouter recommended for flexibility
# ============================================================================

# Provider selection: openrouter | google | openai | cohere
EMBEDDING_PROVIDER=openrouter

# OpenRouter (recommended - unified API for 100+ models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Model selection (optional - defaults to google/gemini-embedding-001)
# Options: google/gemini-embedding-001, openai/text-embedding-3-small, openai/text-embedding-3-large
# EMBEDDING_MODEL=google/gemini-embedding-001

# OR use Google Gemini directly
# Get key: https://aistudio.google.com/apikey
# EMBEDDING_PROVIDER=google
# GEMINI_API_KEY=AIzaSy_your_key_here

# OR use OpenAI directly
# Get key: https://platform.openai.com/api-keys
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your_key_here

# Embedding dimensions (auto-detected from model, override if needed)
# Gemini: 768 or 3072 (default), OpenAI: 1536 or 3072
# EMBEDDING_DIMENSIONS=3072

# ============================================================================
# SEAL Encryption (Optional - Decentralized Encryption)
# https://docs.seal.mysten.app/
# ============================================================================
ENABLE_SEAL_ENCRYPTION=false           # true | false

# SEAL Network Configuration (only needed if ENABLE_SEAL_ENCRYPTION=true)
SEAL_NETWORK=testnet
SEAL_KEY_SERVER_URL=https://testnet.seal.mysten.app

# Key server object IDs on Sui testnet (from SEAL documentation)
SEAL_KEY_SERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
SEAL_KEY_SERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8

# ============================================================================
# Memory Index (auto-created on first run, or from setup script)
# These are populated after running: pnpm run setup:testnet
# ============================================================================
# MEMORY_INDEX_ID=0x_auto_generated
# INDEX_BLOB_ID=_auto_generated_walrus_blob_id
# GRAPH_BLOB_ID=_auto_generated_walrus_blob_id

# ============================================================================
# Chat API Configuration (for Next.js app)
# Uses OpenRouter for chat - same key as embeddings works
# ============================================================================
# OPENROUTER_API_KEY already set above

# ============================================================================
# Development Options
# ============================================================================
# Enable verbose logging
# DEBUG=pdw:*

# Local HNSW index directory (default: .pdw-indexes)
# INDEX_DIRECTORY=.pdw-indexes

# ============================================================================
# HNSW Index Walrus Backup (Optional - Node.js only)
# ============================================================================
# Enable Walrus backup for local HNSW vector index
# When enabled, index is automatically synced to Walrus after each save
# ENABLE_INDEX_WALRUS_BACKUP=false
# INDEX_WALRUS_AUTO_SYNC=true
