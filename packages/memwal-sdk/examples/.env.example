# PDW SDK - Unit Test Environment Variables

# ==================== AI PROVIDERS ====================

# Google Gemini (Primary - Required for most tests)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenAI (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere (Optional)
COHERE_API_KEY=your_cohere_api_key_here

# ==================== BLOCKCHAIN ====================

# Sui Network (testnet or mainnet)
SUI_NETWORK=testnet

# Sui Private Key (Required for E2E tests)
SUI_PRIVATE_KEY=suiprivkey1...

# PDW Package ID (deployed smart contract)
PACKAGE_ID=0x...

# Memory Index ID (created by setup:testnet script)
# Run `npm run setup:testnet` to create this
MEMORY_INDEX_ID=0x...

# ==================== WALRUS STORAGE ====================

# Walrus Network
WALRUS_NETWORK=testnet

# Walrus endpoints (optional - uses defaults)
# WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# ==================== OTHER CONFIGS ====================

# Node environment
NODE_ENV=development

# Enable debug logs
DEBUG=true

# ==================== NOTES ====================
#
# 1. Get Gemini API Key: https://makersuite.google.com/app/apikey
# 2. Get OpenAI API Key: https://platform.openai.com/api-keys
# 3. Get Cohere API Key: https://dashboard.cohere.com/api-keys
# 4. SUI testnet tokens: https://discord.gg/sui (request in #testnet-faucet)
# 5. Copy this file to .env and fill in your keys
