# Server
PORT=3001

# Database
DB_PATH=./data/memwal.db

# Vector dimensions (text-embedding-3-small = 1536)
VECTOR_DIMENSIONS=1536

# OpenAI-compatible API (for embedding)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# Sui Network (for onchain verification)
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Server wallet (deployer = TEE admin) — required for Walrus relay upload + SEAL decrypt
SERVER_SUI_PRIVATE_KEY=suiprivkey1...

# SEAL / Contract — required
MEMWAL_PACKAGE_ID=0x...
MEMWAL_REGISTRY_ID=0x...
