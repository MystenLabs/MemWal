# MemWal V2 Web App — Environment Config
# Copy this to .env.local and fill in your values

# Enoki API Key (get from https://portal.enoki.mystenlabs.com)
VITE_ENOKI_API_KEY=

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# MemWal V2 Package ID on Sui (testnet)
VITE_MEMWAL_PACKAGE_ID=0x93c775e573c0d9aefc0908cc9bb5b0952e131ab6c40b2b769c8b74bb991d34a0

# MemWal Server URL
VITE_MEMWAL_SERVER_URL=http://localhost:3001

# Sui Network
VITE_SUI_NETWORK=testnet
