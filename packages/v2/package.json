{
    "name": "@cmdoss/memwal-v2",
    "version": "2.0.0-alpha.2",
    "description": "MemWal V2 — Privacy-first AI memory SDK with Ed25519 delegate key auth",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
