# Reference Nautilus manifest values for the Walrus Memory relayer.
#
# Nautilus manifest schemas can change. Treat this as the Walrus Memory-specific
# input to carry into the manifest generated by your installed Nautilus CLI.
# This file does not replace the platform-specific Nautilus build/deploy flow
# or the attestation/onchain verification configuration for that deployment.

[project]
name = "memwal-relayer"
template = "memwal-relayer"

[image]
# The Makefile builds services/server/Dockerfile as memwal-relayer:runtime, then
# builds this wrapper image so Nautilus gets a stable entrypoint and env checks.
context = "."
dockerfile = "services/server/deploy/nautilus/Containerfile"
tag = "memwal-relayer:nautilus"

[runtime]
entrypoint = "/app/run.sh"
port = 8000
health_path = "/health"

[resources]
cpu_count = 2
memory_mib = 4096

[sui]
network = "mainnet"
package_id = "0x..."
registry_id = "0x..."

# Fill these with the objects Nautilus creates or requires for your deployment.
config_object_id = "0x..."
cap_object_id = "0x..."
enclave_id = "0x..."

[secrets]
runtime_env = "runtime.env"

[attestation]
# Replace after the first reproducible build, then publish this value to clients
# or an ingress/onchain policy that verifies Nautilus attestation.
expected_measurement = "replace-with-nautilus-image-measurement"
