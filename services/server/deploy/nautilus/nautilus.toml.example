# Reference Nautilus manifest for the MemWal relayer.
#
# Nautilus manifest schemas can change. Treat this as the MemWal-specific
# values to carry into the manifest generated by your installed Nautilus CLI.

[project]
name = "memwal-relayer"
template = "memwal-relayer"

[image]
context = "services/server"
dockerfile = "services/server/Dockerfile"
tag = "memwal-relayer:nautilus"

[runtime]
entrypoint = "./memwal-server"
port = 8000
health_path = "/health"

[resources]
cpu_count = 2
memory_mib = 4096

[sui]
network = "mainnet"
package_id = "0x..."
registry_id = "0x..."

# Fill these with the objects Nautilus creates or requires for your deployment.
config_object_id = "0x..."
cap_object_id = "0x..."
enclave_id = "0x..."

[secrets]
runtime_env = "runtime.env"

[attestation]
# Replace after the first reproducible build, then publish this value to clients
# or an ingress policy that verifies Nautilus attestation.
expected_measurement = "replace-with-nautilus-image-measurement"
