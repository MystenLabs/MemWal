# Walrus Memory relayer runtime env for TEE deployments.
# Store the filled file in your Nautilus/CI secret store. Do not commit it.

# Server
PORT=8000
RUST_LOG=memwal_server=info,tower_http=info
LOG_FORMAT=json
BENCHMARK_MODE=false
ALLOWED_ORIGINS=https://your-app.example.com
# Optional Slack incoming webhook URL for terminal Walrus upload failures.
# ALERT_TO_SLACK=https://hooks.slack.com/services/...

# Database and Redis
DATABASE_URL=postgresql://memwal:<password>@postgres.example.com:5432/memwal?sslmode=require
REDIS_URL=rediss://default:<password>@redis.example.com:6379

# Sui and Walrus Memory contracts
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
MEMWAL_PACKAGE_ID=0x...
MEMWAL_REGISTRY_ID=0x...

# Server wallet. SERVER_SUI_PRIVATE_KEYS takes priority for upload jobs.
SERVER_SUI_PRIVATE_KEY=suiprivkey1...
SERVER_SUI_PRIVATE_KEYS=suiprivkey1...,suiprivkey1...

# SEAL. Optional override; testnet has a built-in Mysten committee default.
# Set SEAL_SERVER_CONFIGS when you need a custom committee aggregator.
# SEAL_SERVER_CONFIGS=[{"objectId":"0x...","weight":1,"aggregatorUrl":"https://seal-aggregator.example.com"}]
# SEAL_KEY_SERVERS=0x...,0x...
# SEAL_THRESHOLD=1

# Walrus
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
# WALRUS_PACKAGE_ID=0x...
# WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space

# Embedding and LLM provider
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# Sidecar stays inside the enclave.
SIDECAR_PORT=9000
SIDECAR_URL=http://127.0.0.1:9000
SIDECAR_SCRIPTS_DIR=/app/scripts
SIDECAR_AUTH_TOKEN=replace-with-32-byte-random-secret

# Redis-backed ciphertext cache
BLOB_CACHE_TTL_SECS=1209600
BLOB_CACHE_MAX_BYTES=524288

# Optional Enoki sponsorship
ENOKI_API_KEY=
ENOKI_NETWORK=mainnet
ENOKI_FALLBACK_TO_DIRECT_SIGN=false

# Optional host-side VSOCK forwarding helpers. Use these only if your Nautilus
# target exposes ingress/egress through a Nitro-style host bridge.
HOST_HTTP_PORT=8000
TEE_HTTP_VSOCK_PORT=8000
SUI_PROXY_VSOCK_PORT=8101
WALRUS_PUBLISHER_PROXY_VSOCK_PORT=8102
WALRUS_AGGREGATOR_PROXY_VSOCK_PORT=8103
POSTGRES_PROXY_VSOCK_PORT=8104
REDIS_PROXY_VSOCK_PORT=8105
OPENAI_PROXY_VSOCK_PORT=8106
WALRUS_UPLOAD_RELAY_PROXY_VSOCK_PORT=8107
SEAL_BASE_VSOCK_PORT=8110
# Comma-separated endpoint URLs for host-forwarder.sh. Keep this aligned with
# SEAL_SERVER_CONFIGS or SEAL_KEY_SERVERS when host-side forwarding is used.
# SEAL_KEY_SERVER_URLS=https://seal-aggregator.example.com
