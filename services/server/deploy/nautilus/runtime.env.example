# MemWal relayer runtime env for Nautilus TEE deployments.
# Store the filled file in your Nautilus/CI secret store. Do not commit it.

# Server
PORT=8000
RUST_LOG=memwal_server=info,tower_http=info
LOG_FORMAT=json
ALLOWED_ORIGINS=https://your-app.example.com

# Database and Redis
DATABASE_URL=postgresql://memwal:<password>@postgres.example.com:5432/memwal?sslmode=require
REDIS_URL=rediss://default:<password>@redis.example.com:6379

# Sui and MemWal contracts
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
MEMWAL_PACKAGE_ID=0x...
MEMWAL_REGISTRY_ID=0x...

# Server wallet. SERVER_SUI_PRIVATE_KEYS takes priority for upload jobs.
SERVER_SUI_PRIVATE_KEY=suiprivkey1...
SERVER_SUI_PRIVATE_KEYS=suiprivkey1...,suiprivkey1...

# SEAL. Prefer SEAL_SERVER_CONFIGS for committee servers.
SEAL_SERVER_CONFIGS=[{"objectId":"0x...","weight":1,"aggregatorUrl":"https://seal-aggregator.example.com"}]
# SEAL_KEY_SERVERS=0x...,0x...
SEAL_THRESHOLD=1

# Walrus
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
# WALRUS_PACKAGE_ID=0x...
# WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space

# Embedding and LLM provider
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# Sidecar stays inside the enclave.
SIDECAR_PORT=9000
SIDECAR_URL=http://127.0.0.1:9000
SIDECAR_SCRIPTS_DIR=/app/scripts

# Redis-backed ciphertext cache
BLOB_CACHE_TTL_SECS=1209600
BLOB_CACHE_MAX_BYTES=524288

# Optional Enoki sponsorship
ENOKI_API_KEY=
ENOKI_NETWORK=mainnet
ENOKI_FALLBACK_TO_DIRECT_SIGN=false
