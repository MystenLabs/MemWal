# Server
PORT=8000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://memwal:memwal_secret@localhost:5432/memwal

# OpenAI-compatible API (for embedding)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# Sui Network (for onchain verification)
# Controls all network-dependent defaults (RPC, Walrus, SEAL)
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Walrus Storage (publisher + aggregator)
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space

# Server wallet (deployer = TEE admin) — required for SEAL decrypt
SERVER_SUI_PRIVATE_KEY=suiprivkey1...

# Key pool for parallel Walrus uploads (up to 5 wallets round-robin)
# Each wallet needs SUI + WAL tokens
SERVER_SUI_PRIVATE_KEYS=suiprivkey1...,suiprivkey1...

# Contract IDs — required
MEMWAL_PACKAGE_ID=0x...
MEMWAL_REGISTRY_ID=0x...

# SEAL key servers (comma-separated object IDs)
# Required for SEAL encrypt/decrypt in sidecar scripts
SEAL_KEY_SERVERS=0x...,0x...

# Walrus on-chain package ID (auto-detected from SUI_NETWORK if not set)
# WALRUS_PACKAGE_ID=0x...

# Walrus upload relay (auto-detected from SUI_NETWORK if not set)
# WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space

# Enoki Sponsored Transactions (sidecar)
ENOKI_API_KEY=
ENOKI_NETWORK=mainnet

# ═════════════════════════════════════════════════════════════════════
# Benchmark mode — retrieval quality testing only
# ═════════════════════════════════════════════════════════════════════
#
# WARNING: When BENCHMARK_MODE=true, the server skips SEAL encryption
# and Walrus uploads entirely. Memory plaintext is stored directly in
# Postgres. This is UNSAFE for production data — never enable this on
# a server that handles real user data.
#
# What benchmark mode does:
#   - Skips TS sidecar startup (no SEAL, no Walrus client)
#   - Writes/reads plaintext via a nullable `plaintext` column in
#     vector_entries (added by migration 005)
#   - Tags rows with `bench:{uuid}` blob_id prefix so they're clearly
#     distinguishable from production rows
#   - Logs a loud warning banner at startup
#
# Scope of the branching: /api/analyze, /api/recall, /api/remember, and
# the write paths of /api/consolidate are fully branched. /api/ask,
# /api/restore, /api/remember/manual, and the standalone consolidate
# decrypt path still call SEAL/Walrus unconditionally — hitting them
# in benchmark mode will fail loudly rather than corrupt data.
#
# To run the retrieval quality benchmarks in services/server/benchmarks/,
# uncomment the three lines below. You'll also want to bump the rate
# limits since the default 30/min delegate-key cap isn't enough for
# parallel benchmark workers.

# BENCHMARK_MODE=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=100000
# RATE_LIMIT_REQUESTS_PER_HOUR=1000000
# RATE_LIMIT_DELEGATE_KEY_PER_MINUTE=100000
