{
  "name": "memwal-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/researcher && npm run dev",
    "dev:researcher": "cd apps/researcher && npm run dev",
    "dev:showcase": "cd apps/showcase && npm run dev",
    "build": "npm run build:v2 && npm run build:researcher",
    "build:v2": "cd packages/v2 && npm run build",
    "build:sdk": "cd packages/memwal-sdk && npm run build",
    "build:researcher": "cd apps/researcher && npm run build",
    "build:showcase": "cd apps/showcase && npm run build",
    "start": "cd apps/researcher && npm run start",
    "lint": "cd apps/researcher && npm run lint",
    "lint:showcase": "cd apps/showcase && npm run lint",
    "db:generate": "cd apps/researcher && npm run db:generate",
    "db:migrate": "cd apps/researcher && npm run db:migrate",
    "db:studio": "cd apps/researcher && npm run db:studio",
    "db:push": "cd apps/researcher && npm run db:push",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules node_modules apps/*/.next packages/*/dist bun.lock package-lock.json",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "version": "changeset version",
    "release": "npm run build:sdk && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "lightningcss-darwin-arm64": "^1.30.2"
  }
}
