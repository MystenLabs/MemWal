{
  "name": "memwal-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf packages/*/node_modules node_modules packages/*/dist package-lock.json",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "version": "changeset version",
    "release": "npm run build:sdk && changeset publish",
    "build:sdk": "cd packages/v2 && npm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2"
}
