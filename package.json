{
  "name": "memwal-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/showcase && bun run dev",
    "dev:showcase": "cd apps/showcase && bun run dev",
    "build": "bun run build:sdk && bun run build:showcase",
    "build:sdk": "cd packages/memwal-sdk && bun run build",
    "build:showcase": "cd apps/showcase && bun run build",
    "start": "cd apps/showcase && bun run start",
    "lint": "bun run lint:sdk && bun run lint:showcase",
    "lint:sdk": "cd packages/memwal-sdk && bun run lint",
    "lint:showcase": "cd apps/showcase && bun run lint",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules node_modules apps/*/.next packages/*/dist",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "version": "changeset version",
    "release": "bun run build:sdk && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "typescript": "^5"
  },
  "packageManager": "bun@1.0.0"
}
