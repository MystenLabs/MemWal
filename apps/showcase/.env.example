# Sui Network Configuration
SUI_NETWORK=
# PDW Smart Contract Configuration
PACKAGE_ID=

# Client-side Configuration (for DappKitSigner)
# These are exposed to the browser for client-side SDK usage
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
# ACCESS_REGISTRY_ID=
# WALLET_REGISTRY_ID=
# Google Gemini API for embeddings
GEMINI_API_KEY=
# Walrus Configuration
WALRUS_PUBLISHER=
WALRUS_AGGREGATOR=
# Sui Wallet
WALLET_ADDRESS=
SUI_PRIVATE_KEY=
# Memory Index On-Chain (created by setup:testnet script)
# MEMORY_INDEX_ID: Sui object ID of the MemoryIndex - this is STABLE and reusable
# INDEX_BLOB_ID: Current Walrus blob ID for HNSW index (updated after each sync)
# GRAPH_BLOB_ID: Current Walrus blob ID for knowledge graph
#
# Usage:
# 1. Run setup:testnet to create initial MemoryIndex and placeholder blobs
# 2. Call /api/index/update to sync index to Walrus AND update on-chain
# 3. The new blob IDs are returned in the response (can update .env if needed)
#
# Note: MEMORY_INDEX_ID is stable - same object ID is used for all updates
# INDEX_BLOB_ID and GRAPH_BLOB_ID change with each sync (new blob uploaded to Walrus)
MEMORY_INDEX_ID=
INDEX_BLOB_ID=
GRAPH_BLOB_ID=
# OpenAI API Key (required for basic-rag.ts example)
# OPENAI_API_KEY=
# SEAL Encryption Configuration
SEAL_KEY_SERVER_URL=
SEAL_NETWORK=
# Key server object IDs on Sui testnet (from SEAL documentation)
SEAL_KEY_SERVER_1=
SEAL_KEY_SERVER_2=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OpenRouter API Key (for chat with multiple LLM providers)
OPENROUTER_API_KEY=

# Embedding Configuration (optional - SDK uses smart defaults)
# Provider: google, openai, openrouter, cohere
EMBEDDING_PROVIDER=openrouter
# API Key: uses OPENROUTER_API_KEY or GEMINI_API_KEY if not set
EMBEDDING_API_KEY=
# Model: defaults to google/text-embedding-004 for openrouter
EMBEDDING_MODEL=
# Dimensions: 768 (default, fast), 1536, 3072 (highest quality, slowest)
# Lower = faster embedding generation + smaller storage + faster search
EMBEDDING_DIMENSIONS=768