# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# OpenRouter API key — get it from https://openrouter.ai/keys
OPENROUTER_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****

# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****

# Walrus Memory SDK — server-side delegate private key for memory layer.
# Get these values from the Walrus Memory dashboard. Run `pnpm verify:memwal` before starting.
MEMWAL_PRIVATE_KEY=****
MEMWAL_ACCOUNT_ID=0x...
# Optional: paste the dashboard delegate public key so `pnpm verify:memwal` can catch mismatches.
MEMWAL_DELEGATE_PUBLIC_KEY=
MEMWAL_SERVER_URL=http://localhost:8000
