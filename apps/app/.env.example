# MemWal V2 Web App — Environment Config
# Copy this to .env.local and fill in your values

# Enoki API Key (get from https://portal.enoki.mystenlabs.com)
VITE_ENOKI_API_KEY=

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# MemWal V2 Package ID on Sui (testnet)
VITE_MEMWAL_PACKAGE_ID=0xb625c403a26c4b985a3f2549e6115c1646b0094d39fa142016807ba015952869

# MemWal V2 Registry Object ID on Sui (testnet)
VITE_MEMWAL_REGISTRY_ID=0x3d46792b7676e6558707982b535092454a46e668b52c0a6d83b9a9fdecd71c46

# MemWal Server URL
VITE_MEMWAL_SERVER_URL=http://localhost:8000

# Sui Network
VITE_SUI_NETWORK=testnet
