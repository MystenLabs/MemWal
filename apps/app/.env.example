# ══════════════════════════════════════════════════════════════
# MemWal App — Environment Configuration
# ══════════════════════════════════════════════════════════════
# To switch networks: uncomment one block, comment out the other.
# ══════════════════════════════════════════════════════════════

# Enoki API Key (get from https://portal.enoki.mystenlabs.com)
VITE_ENOKI_API_KEY=

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# MemWal Server URL
VITE_MEMWAL_SERVER_URL=http://localhost:8000

# Docs URL (separate deployment)
VITE_DOCS_URL=http://localhost:5174

# ══════════════════════════════════════════════════════════════
# ▶ ACTIVE: MAINNET
# ══════════════════════════════════════════════════════════════
VITE_SUI_NETWORK=mainnet
VITE_MEMWAL_PACKAGE_ID=0xcee7a6fd8de52ce645c38332bde23d4a30fd9426bc4681409733dd50958a24c6
VITE_MEMWAL_REGISTRY_ID=0x0da982cefa26864ae834a8a0504b904233d49e20fcc17c373c8bed99c75a7edd

# ══════════════════════════════════════════════════════════════
# ▷ INACTIVE: TESTNET  (uncomment below, comment out MAINNET above)
# ══════════════════════════════════════════════════════════════
# VITE_SUI_NETWORK=testnet
# VITE_MEMWAL_PACKAGE_ID=0x12b28adbe55c25341f08b8ad9ac69462aab917048c7cd5b736d951200090ee3f
# VITE_MEMWAL_REGISTRY_ID=0xfb8a1d298e2a73bdab353da3fcb3b16f68ab7d1f392f3a5c4944c747c026fc05
