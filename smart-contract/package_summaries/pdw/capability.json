    "seal_approve": {
      "source_index": 1,
      "index": 1,
      "doc": " SEAL-compliant approval function\n\n This function follows the SEAL PrivateData pattern:\n - Entry function that aborts on denial (SEAL requirement)\n - Object holder can pass seal_approve\n - Any dApp can call with user's connected wallet\n\n Flow:\n 1. Verify caller owns the capability (via object reference)\n 2. Compute expected key_id from capability\n 3. Validate provided key_id matches\n 4. If valid, function returns (access granted)\n 5. If invalid, function aborts (access denied)\n\n @param cap: Reference to the MemoryCap object\n @param key_id: SEAL key identifier to validate\n @param ctx: Transaction context",
      "attributes": [],
      "visibility": "Private",
      "entry": true,
      "type_parameters": [],
      "parameters": [
        {
          "name": "cap",
          "type_": {
            "Reference": [
              false,
              {
                "Datatype": {
                  "module": {
                    "address": "pdw",
                    "name": "capability"
                  },
                  "name": "MemoryCap",
                  "type_arguments": []
                }
              }
            ]
          }
        },
        {
          "name": "key_id",
          "type_": {
            "vector": "u8"
          }
        },
        {
          "name": "ctx",
          "type_": {
            "Reference": [
              false,
              {
                "Datatype": {
                  "module": {
                    "address": "sui",
                    "name": "tx_context"
                  },
                  "name": "TxContext",
                  "type_arguments": []
                }
